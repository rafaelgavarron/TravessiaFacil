{
   "extends": "expo/tsconfig.base",
   "compilerOptions": {
      "jsx": "react-jsx",
      "strict": true,
      "types": ["node"],
      "paths": {
         "@/data/*": ["./data/*"],
         "@/*": ["./src/*"],
         "@/assets/*": ["./assets/*"],
      },
   },
   "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"],
}
